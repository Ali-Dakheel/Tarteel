# ─── App ────────────────────────────────────────────────────────────────────
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate
APP_ENV=local
APP_DEBUG=true

# ─── Database ────────────────────────────────────────────────────────────────
DB_PASSWORD=tarteel_secret

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ─── Internal service auth ───────────────────────────────────────────────────
# Shared secret between Laravel and FastAPI — generate with: openssl rand -hex 32
INTERNAL_API_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── Payments ─────────────────────────────────────────────────────────────────
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
